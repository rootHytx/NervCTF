ctfd_url: <URL of the CTFd instance>
ctfd_api_key: <API key generated in the CTFd instance from an admin acocunt, remember this must be generated manually after nervctf setup>
monitor_url: <URL of the monitor, if not set previously, will defaul to ctfd_url:33133>
monitor_token: <Auto-generated monitor token from nervctf setup>
base_dir: <Relative path from the .nervctf.yml to the top-level challenges directory>
target_ip: <Target machine IP address>
target_user: <Pre-existing user in the machine that has sudo access>
ssh_pubkey_path: <SSH key existing in the /home/target_user/.ssh/authorized_keys file of the target>
ctfd_remote_path: <If already installed, place the full path to the CTFf instance of the remote here>
monitor_port: <Synced with the monitor_url>
